Bootstrap: docker
From: ubuntu:24.04

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update -qq
    apt-get install -y --no-install-recommends \
        software-properties-common \
        dirmngr \
        ca-certificates \
        wget \
        locales

    locale-gen en_US.UTF-8
    update-locale LANG=en_US.UTF-8

    wget -qO- https://cloud.r-project.org/bin/linux/ubuntu/marutter_pubkey.asc \
        | tee /etc/apt/trusted.gpg.d/cran_ubuntu_key.asc
    add-apt-repository "deb https://cloud.r-project.org/bin/linux/ubuntu noble-cran40/"

    apt-get update -qq
    apt-get install -y --no-install-recommends \
        r-base \
        r-base-dev \
        build-essential \
        gfortran \
        pkg-config \
        libcurl4-openssl-dev \
        libssl-dev \
        libxml2-dev \
        libgit2-dev \
        zlib1g-dev \
        libbz2-dev \
        liblzma-dev \
        libpcre2-dev \
        libreadline-dev \
        libicu-dev

    R -q -e 'install.packages("BiocManager", repos="https://cloud.r-project.org")'
    R -q -e 'BiocManager::install(c("argparse","anndataR","SingleCellExperiment", "TENxBrainData"), Ncpus=8)'

    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export LANG=en_US.UTF-8
    export LC_ALL=en_US.UTF-8

%test
    R --version
    R -q -e 'library(BiocManager); sessionInfo()'

%runscript
    exec R "$@"
